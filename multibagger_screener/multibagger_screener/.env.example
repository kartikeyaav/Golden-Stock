# Copy this file to .env and fill in real values. Never commit the real .env.
# Zerodha Kite Connect — https://developers.kite.trade
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# access_token is generated fresh via the login flow EVERY trading day —
# see data/kite_client.py docstring for the exact steps. Don't hardcode a
# long-lived value here; write a small script that refreshes it each morning
# and updates your environment/.env programmatically before market open.
KITE_ACCESS_TOKEN=refresh_this_daily
